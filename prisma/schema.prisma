generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CmsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
}

model HomePageContent {
  id          String    @id @default(cuid())
  locale      String    @default("fr")
  status      CmsStatus @default(DRAFT)
  title       String?
  sections    Json      @default("[]")
  draftData   Json?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([locale, status])
  @@index([locale, status])
}

model HeroSection {
  id                   String      @id @default(cuid())
  locale               String      @default("fr")
  status               CmsStatus   @default(DRAFT)
  eyebrow              String
  title                String
  description          String      @db.Text
  ctaLabel             String
  ctaHref              String
  secondaryCtaLabel    String?
  secondaryCtaHref     String?
  whatsappMessage      String?
  heroVideoUrl         String?
  features             Json        @default("[]")
  carouselImages       Json        @default("[]")
  backgroundVideoId    String?
  backgroundVideo      MediaAsset? @relation("HeroVideo", fields: [backgroundVideoId], references: [id], onDelete: SetNull)
  isActive             Boolean     @default(true)
  sortOrder            Int         @default(0)
  publishedAt          DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([locale, status])
  @@index([locale, status, isActive])
}

model ServiceSection {
  id          String    @id @default(cuid())
  locale      String    @default("fr")
  status      CmsStatus @default(DRAFT)
  slug        String
  title       String
  description String    @db.Text
  icon        String    @default("Sparkles")
  tone        String    @default("cyan")
  href        String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([locale, status, slug])
  @@index([locale, status, isActive, sortOrder])
}

model Testimonial {
  id          String    @id @default(cuid())
  locale      String    @default("fr")
  status      CmsStatus @default(DRAFT)
  quote       String    @db.Text
  name        String
  role        String
  avatarId    String?
  avatar      MediaAsset? @relation("TestimonialAvatar", fields: [avatarId], references: [id], onDelete: SetNull)
  rating      Int       @default(5)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([locale, status, isActive, sortOrder])
}

model FAQ {
  id          String    @id @default(cuid())
  locale      String    @default("fr")
  status      CmsStatus @default(DRAFT)
  question    String
  answer      String    @db.Text
  category    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([locale, status, isActive, sortOrder])
}

model SeoMetadata {
  id             String    @id @default(cuid())
  locale         String    @default("fr")
  status         CmsStatus @default(DRAFT)
  pagePath       String    @default("/")
  title          String
  description    String    @db.Text
  keywords       String[]  @default([])
  ogImageId      String?
  ogImage        MediaAsset? @relation("SeoOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)
  structuredData Json?
  noIndex        Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([locale, status, pagePath])
  @@index([locale, status, pagePath])
}

model MediaAsset {
  id          String    @id @default(cuid())
  kind        MediaKind
  provider    String    @default("local")
  url         String
  secureUrl   String?
  publicId    String?
  filename    String
  alt         String?
  mimeType    String
  width       Int?
  height      Int?
  duration    Float?
  sizeBytes   Int
  folder      String    @default("cms")
  metadata    Json?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  heroVideos          HeroSection[] @relation("HeroVideo")
  testimonialAvatars  Testimonial[] @relation("TestimonialAvatar")
  seoOgImages         SeoMetadata[] @relation("SeoOgImage")

  @@index([kind, isActive, createdAt])
  @@index([provider, publicId])
}
